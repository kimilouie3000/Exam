            "type": "integer",
            "format": "int32"
          },
          "courseId": {
            "type": "integer",
            "format": "int32"
          },
          "semester": {
            "minLength": 1,
            "type": "string"
          },
          "grade": {
            "maximum": 5,
            "minimum": 1,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "Instructor": {
        "required": [
          "employeeNo",
          "firstName",
          "lastName"
        ],
        "type": "object",
        "properties": {
          "instructorId": {
            "type": "integer",
            "format": "int32"
          },
          "employeeNo": {
            "minLength": 1,
            "type": "string"
          },
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "departmentId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Section": {
        "required": [
          "room",
          "schedule",
          "sectionCode"
        ],
        "type": "object",
        "properties": {
          "sectionId": {
            "type": "integer",
            "format": "int32"
          },
          "sectionCode": {
            "minLength": 1,
            "type": "string"
          },
          "courseId": {
            "type": "integer",
            "format": "int32"
          },
          "instructorId": {
            "type": "integer",
            "format": "int32"
          },
          "room": {
            "minLength": 1,
            "type": "string"
          },
          "schedule": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Student": {
        "required": [
          "firstName",
          "lastName",
          "studentNo"
        ],
        "type": "object",
        "properties": {
          "studentId": {
            "type": "integer",
            "format": "int32"
          },
          "studentNo": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "birthDate": {
            "type": "string",
            "format": "date-time"
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          }
        },
        "additionalProperties": false
